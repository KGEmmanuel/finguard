{
  "name": "finguard-monorepo",
  "private": true,
  "version": "2.1.0",
  "type": "module",
  "scripts": {
    "build": "tsc -b packages/pack-spec packages/verify",
    "typecheck": "tsc -b packages/pack-spec packages/verify",
    "test": "tsx --test packages/pack-spec/test/canonical.test.ts packages/pack-spec/test/manifest.test.ts packages/verify/test/verify.test.ts",
    "golden:update": "tsx scripts/build-golden.ts",
    "golden:check": "tsx scripts/check-golden.ts",
    "lint": "pnpm typecheck",
    "verify": "pnpm typecheck && pnpm build && pnpm test && pnpm golden:check && node packages/verify/dist/cli.js fixtures/golden-pack/output/finguard-evidence-golden.zip --no-color",
    "postinstall": "node -e \"try{require('node:child_process').execSync('git config core.hooksPath .githooks',{stdio:'ignore'})}catch{}\""
  },
  "devDependencies": {
    "@finguard/pack-spec": "workspace:*",
    "@types/node": "^22.10.0",
    "fflate": "^0.8.2",
    "tsx": "^4.19.0",
    "typescript": "^5.6.0"
  }
}
